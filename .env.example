# IB Gateway connection (ib_async)
IB_TRADING_MODE=paper          # paper | live
IB_HOST=127.0.0.1
IB_PORT=                       # optional override; defaults to 4002 (paper) / 4001 (live)
IB_CLIENT_ID=1

# Risk parity monitor
DRIFT_THRESHOLD_PCT=5.0
CHECK_INTERVAL_SECS=3600
# Cash-like tickers held as a separate sleeve, kept OUT of the risk-parity
# optimiser (a near-zero-vol asset can't be equal-risk-sized — it would get a
# garbage target). Pinned to their current weight, so no false drift alert.
CASH_TICKERS=SGOV
# Stop-loss recommender: alert (never an order) when a risky position is down
# this many % from YOUR average cost (the lot you bought). 0 disables.
STOP_LOSS_PCT=15.0

# ntfy.sh push notifications
NTFY_ENABLED=off               # on | off
NTFY_TOPIC=
